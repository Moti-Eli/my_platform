{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(pnpm *)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(supabase status*)",
      "Bash(supabase db push*)",
      "Bash(supabase db diff*)",
      "Bash(supabase db pull*)",
      "Bash(supabase db lint*)",
      "Bash(supabase migration list*)",
      "Bash(supabase migration new*)",
      "Bash(supabase migration up*)",
      "Bash(supabase gen *)",
      "Bash(supabase projects list*)",
      "Bash(tsx verify-*)",
      "Bash(npx tsx verify-*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push --delete*)",
      "Bash(git push origin --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -Rf*)",
      "Bash(rm -r *)",
      "Bash(rm -f *)",
      "Bash(supabase db reset*)",
      "Bash(supabase projects delete*)",
      "Bash(supabase link*)",
      "Bash(supabase * --linked*)",
      "Bash(supabase * --db-url*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP SCHEMA*)",
      "Bash(*TRUNCATE *)",
      "Bash(pnpm publish*)",
      "Bash(npm publish*)",
      "Bash(pnpm exec*)",
      "Bash(pnpm dlx*)",
      "Bash(pnpm x *)",
      "Bash(git commit --amend*)",
      "Bash(git push --mirror*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog expire*)",
      "Bash(git stash clear*)",
      "Bash(git add .env*)",
      "Bash(git add *id_rsa*)",
      "Bash(rmdir*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)"
    ]
  }
}

# Supabase Configuration
#
# Supabase replaced its legacy JWT-based API keys with new key types in 2025.
# New projects (from 1 Nov 2025) only have the new keys. We use the new names.
# Find these in: Supabase Dashboard -> Project Settings -> API Keys.
#
# Project URL (unchanged): https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
#
# Publishable key (formerly the "anon" key). Format: sb_publishable_...
# Low-privilege, safe to expose in client/browser code. Subject to RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Secret key (formerly the "service_role" key). Format: sb_secret_...
# Full-privilege, bypasses RLS. SERVER-SIDE ONLY — never expose to the client
# (note: no NEXT_PUBLIC_ prefix, so Next.js will not ship it to the browser).
SUPABASE_SECRET_KEY=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
API_SECRET=

# Feature Flags
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Observability (all OPTIONAL)
#
# App code never imports a vendor SDK directly — it uses @platform/observability.
# With NO values set, errors are structured-logged to the console (JSON lines) and
# nothing else happens. Error reporting (Sentry) activates ONLY when a DSN is set.
#
# Minimum log level: debug | info | warn | error. Default: debug off-prod, info in prod.
LOG_LEVEL=
#
# Sentry DSN (server). When set, the Sentry SERVER adapter initializes and errors
# are reported there (in addition to the console log). Leave empty to disable.
# Never commit a real DSN. Get it from your Sentry project settings.
SENTRY_DSN=
#
# Sentry DSN (browser). Public (NEXT_PUBLIC_) so the client adapter can init.
# Usually the same DSN value as SENTRY_DSN. Leave empty to disable client reporting.
NEXT_PUBLIC_SENTRY_DSN=
#
# Optional Sentry tracing sample rate (0..1). Default 0 (tracing off).
SENTRY_TRACES_SAMPLE_RATE=

{
  "name": "@platform/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile application (Expo + Expo Router)",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform android --output-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Mobile lint is configured in a later step'"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@platform/auth": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/core": "workspace:*",
    "@platform/db": "workspace:*",
    "@platform/i18n": "workspace:*",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-url-polyfill": "~3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "typescript": "~5.9.3"
  }
}

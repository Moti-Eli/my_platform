# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the app bundle
# (the equivalent of NEXT_PUBLIC_ on the web). These are embedded in the
# client, so ONLY put public, low-privilege values here.
#
# Copy this file to `.env.local` (gitignored) and fill in real values:
#   cp .env.example .env.local

# Supabase project URL (same project as the web app).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase PUBLISHABLE (anon) key — safe to ship in a client.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Base URL of the web app that hosts the privileged admin API endpoints
# (/api/admin/*). The mobile app calls these with the user's Bearer token for
# operations that need the secret key server-side (add user, create org).
#   production = the deployed Vercel URL, e.g. https://your-app.vercel.app
#   dev        = your machine's LAN IP so a physical device can reach it,
#                e.g. http://192.168.1.50:3000  (NOT localhost — that's the phone)
EXPO_PUBLIC_API_URL=http://192.168.1.50:3000

# NEVER put the secret/service-role key in the mobile app — it is a client,
# same rule as the web app. The secret key stays server-side only.
